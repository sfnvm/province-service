# Template for the `dev` Spring profile (real DB over WireGuard).
# Copy to dev.env and fill in, OR generate from the k8s project:
#   grep -E '^(POSTGRES_APP_USER|POSTGRES_APP_PASSWORD|POSTGRES_APP_DBNAME|POSTGRES_APP_VPN_PRIMARY_HOST|POSTGRES_APP_VPN_PORT|POSTGRES_APP_VPN_SSLMODE)=' \
#     ~/sauces/k8s/configs/postgres-cnpg/local-secret-postgres-app.env > dev.env
# dev.env is gitignored — never commit real credentials.
POSTGRES_APP_USER=
POSTGRES_APP_PASSWORD=
POSTGRES_APP_DBNAME=
POSTGRES_APP_VPN_PRIMARY_HOST=
POSTGRES_APP_VPN_PORT=
POSTGRES_APP_VPN_SSLMODE=
