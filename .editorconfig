root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Match ktfmt googleStyle (Spotless source of truth)
[*.{kt,kts}]
indent_style = space
indent_size = 2
continuation_indent_size = 4
ij_continuation_indent_size = 4
max_line_length = 100

[*.{yml,yaml,json}]
indent_style = space
indent_size = 2
